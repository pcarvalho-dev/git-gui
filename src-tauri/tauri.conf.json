{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GitArc",
  "version": "1.5.0",
  "identifier": "com.gitarc.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "GitArc",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "linux": {
      "deb": {
        "conflicts": ["git-gui"],
        "replaces": ["git-gui"]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEUwNjYzNjUxQzY5QTMyMTgKUldRWU1wckdVVFptNEZoMXdEdUs3d2h3aHpZZWtKM1JzdzlDVWcxc20zb0RDbG5XWjdzZEp4S1oK",
      "endpoints": [
        "https://github.com/pcarvalho-dev/git-gui/releases/latest/download/latest.json"
      ]
    }
  }
}

